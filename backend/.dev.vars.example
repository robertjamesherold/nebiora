# Copy to .dev.vars for local `wrangler dev` runs (gitignored).

# Loosen CORS so the local Vite dev server (http://localhost:5173) can call this worker.
ALLOWED_ORIGIN=http://localhost:5173

# Get a free API key at https://resend.com/api-keys (no credit card required).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Until you verify your own domain in Resend, you can only send test emails
# from onboarding@resend.dev to the email address you signed up with.
CONTACT_TO_ADDRESS=your-signup-address@example.com

# cal.com API key (Settings → Security → API Keys in the cal.com dashboard).
CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile secret key for the widget covering localhost/127.0.0.1/nebiora.studio
# (dash.cloudflare.com → Turnstile). Never the sitekey — that one's public and lives in the frontend.
TURNSTILE_SECRET=0x4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
