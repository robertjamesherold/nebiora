# URL of the deployed backend contact endpoint (see /backend).
# Defaults to http://localhost:8787/api/contact for local development against `npm run dev --prefix backend`.
VITE_CONTACT_API_URL=https://nebiora-backend.<your-subdomain>.workers.dev/api/contact

# Base URL of the deployed backend booking endpoints (see /backend) — /slots and
# /create are appended. Defaults to http://localhost:8787/api/booking for local
# development against `npm run dev --prefix backend`.
VITE_BOOKING_API_URL=https://nebiora-backend.<your-subdomain>.workers.dev/api/booking
