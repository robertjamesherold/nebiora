{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nebiora-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-17",
  "vars": {
    "ALLOWED_ORIGIN": "https://nebiora.studio",
    "CONTACT_TO_ADDRESS": "hallo@nebiora.studio",
    "CONTACT_FROM_ADDRESS": "onboarding@resend.dev",
  },
  // RESEND_API_KEY is a secret, not a var — set it with:
  //   npx wrangler secret put RESEND_API_KEY
  // and for local dev, add it to backend/.dev.vars (gitignored).
}
