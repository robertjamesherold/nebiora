{
    "allowManagedHooksOnly": true,
    "allowManagedPermissionRulesOnly": true,
    "allowManagedMcpServersOnly": true,
    "permissions": {
        "deny": [
            "Bash(curl*|wget*)",
            "Bash(npm publish*)",
            "Bash(git push --force*)",
            "Read(~/.ssh/*)",
            "Read(~/.aws/*)",
            "Read(**/.env*)",
            "Read(**/secrets.*)"
        ],
        "ask": [
            "Bash(git push*)",
            "Bash(docker run*)",
            "Bash(npm exec*)"
        ],
        "allow": [
            "Bash(git diff*)",
            "Bash(git log*)",
            "Bash(npm test*)",
            "Bash(npm lint*)",
            "Bash(npm build*)"
        ]
    },
    "enabledMcpServers": [
        "github",
        "linear",
        "sentry"
    ],
    "transcriptRetentionDays": 14
}